{
    "name": "fulcrum/cms",
    "description": "A modern PHP CMS. The core is fixed. Plugins are the leverage.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.3"
    },
    "autoload": {
        "psr-4": {
            "Fulcrum\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable"
}