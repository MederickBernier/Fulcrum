<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login — Fulcrum</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #f5f5f5;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }

        .login-box {
            background: #fff;
            border: 1px solid #e5e5e5;
            border-radius: 8px;
            padding: 40px;
            width: 100%;
            max-width: 400px;
        }

        .login-brand {
            font-size: 24px;
            font-weight: 800;
            color: #1a1a2e;
            margin-bottom: 8px;
        }

        .login-brand span { color: #7c6af7; }

        .login-sub {
            color: #888;
            font-size: 13px;
            margin-bottom: 28px;
        }

        .form-label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            color: #555;
            margin-bottom: 6px;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .form-input {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-size: 14px;
            color: #333;
            transition: border-color 0.15s;
            font-family: inherit;
        }

        .form-input:focus {
            outline: none;
            border-color: #7c6af7;
        }

        .btn {
            width: 100%;
            padding: 10px;
            background: #7c6af7;
            color: #fff;
            border: none;
            border-radius: 4px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 16px;
            font-family: inherit;
        }

        .btn:hover { background: #6a58e0; }

        .alert {
            padding: 12px;
            border-radius: 4px;
            font-size: 13px;
            margin-bottom: 20px;
        }

        .alert-success {
            background: #e6f7ee;
            color: #2d7a4f;
            border: 1px solid #b7e4cc;
        }

        .alert-error {
            background: #fde8e8;
            color: #c0392b;
            border: 1px solid #f5c6c6;
        }

        .dev-link {
            margin-top: 20px;
            padding: 12px;
            background: #fffbe6;
            border: 1px solid #ffe58f;
            border-radius: 4px;
            font-size: 12px;
            color: #856404;
            word-break: break-all;
        }

        .dev-link strong {
            display: block;
            margin-bottom: 4px;
        }

        .dev-link a {
            color: #7c6af7;
        }
    </style>
</head>
<body>
<div class="login-box">

    <div class="login-brand">Ful<span>crum</span></div>
    <div class="login-sub">Enter your email to receive a login link.</div>

    {% if sent %}
        <div class="alert alert-success">
            If that email is registered you'll receive a link shortly.
        </div>
    {% endif %}

    {% if error == 'invalid_token' %}
        <div class="alert alert-error">
            That link is invalid or has expired. Please request a new one.
        </div>
    {% endif %}

    <form method="POST" action="/_fulcrum/login">
        <label class="form-label" for="email">Email address</label>
        <input type="email"
               id="email"
               name="email"
               class="form-input"
               placeholder="you@example.com"
               autofocus
               required>
        <button type="submit" class="btn">Send Login Link</button>
    </form>

    {% if dev_link is defined and dev_link %}
        <div class="dev-link">
            <strong>⚡ Dev mode — your magic link:</strong>
            <a href="{{ dev_link }}">{{ dev_link }}</a>
        </div>
    {% endif %}

</div>
</body>
</html>