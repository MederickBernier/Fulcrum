{% extends 'frontend/layout.html.twig' %}

{% block title %}Home{% endblock %}

{% block content %}

{% if posts is empty %}

    <div style="text-align:center; padding: 60px 0; color:#aaa;">
        <div style="font-size:48px; margin-bottom:16px;">✦</div>
        <p style="font-size:18px; color:#333; margin-bottom:8px;">
            Nothing published yet.
        </p>
        <p>
            <a href="/_fulcrum/content/create">Create your first post →</a>
        </p>
    </div>

{% else %}

    <h1 style="font-size:28px; font-weight:800; margin-bottom:32px; color:#1a1a2e;">
        Latest
    </h1>

    {% for post in posts %}
    <article style="margin-bottom:40px; padding-bottom:40px; border-bottom:1px solid #f0f0f0;">

        <h2 style="font-size:20px; font-weight:700; margin-bottom:8px;">
            <a href="/{{ post.slug }}" style="color:#1a1a2e;">
                {{ post.title }}
            </a>
        </h2>

        <div style="font-size:13px; color:#aaa; margin-bottom:12px;">
            {{ post.created_at|date('F j, Y') }}
        </div>

        {% if post.body %}
            <p style="color:#555; line-height:1.7;">
                {{ post.body|slice(0, 200) }}{% if post.body|length > 200 %}…{% endif %}
            </p>
        {% endif %}

        <div style="margin-top:12px;">
            <a href="/{{ post.slug }}" style="font-size:14px; font-weight:600;">
                Read more →
            </a>
        </div>

    </article>
    {% endfor %}

{% endif %}

{% endblock %}